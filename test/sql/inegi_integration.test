# name: test/sql/inegi_integration.test
# description: Integration tests for INEGI extension with real API calls
# group: [sql]

# NOTE: This test file is designed to run in CI/CD with INEGI_TOKEN environment variable
# The getenv() function is not available in static builds, so these tests are skipped locally
# In GitHub Actions, the INEGI_TOKEN secret is passed as an environment variable

# For now, we just verify the extension loads and basic functionality works
require inegi

# Verify extension is loaded by checking token management works
statement ok
SELECT INEGI_SetToken('test-integration-token');

query I
SELECT INEGI_GetToken();
----
test-integration-token

# Real API integration tests will be added when getenv() is available in the test environment
# or when we implement a different mechanism for passing tokens to tests
