# name: test/sql/inegi_read.test
# description: Test INEGI_Read function (requires valid token and network access)
# group: [inegi]

require inegi

# Test that INEGI_Read fails without token
statement error
SELECT * FROM INEGI_Read('1234567');
----
INEGI API token not set

# Set token from environment variable if available, otherwise use test token
statement ok
SELECT INEGI_SetToken(COALESCE(getenv('INEGI_TOKEN'), 'test-token-12345'));

# Note: Real API tests are in inegi_integration.test
# That test file will only run actual API calls if INEGI_TOKEN is set in environment
