# name: test/sql/inegi_read.test
# description: Test INEGI_Read function (requires valid token and network access)
# group: [sql]

require inegi

# Test that INEGI_Read fails without token
statement error
SELECT * FROM INEGI_Read('1234567');
----
INEGI API token not set

# Set test token (real API tests are in inegi_integration.test)
statement ok
SELECT INEGI_SetToken('test-token-12345');
